generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                  String       @id @default(uuid())
  name                String
  slug                String       @unique
  currencyCode        CurrencyCode @default(ZMW)
  createdAt           DateTime     @default(now())

  address             String?
  phone               String?
  email               String?
  logoUrl             String?

  bankName            String?
  accountName         String?
  accountNumber       String?
  branchName          String?
  airtelMoneyNumber   String?
  mtnMoneyNumber      String?
  paymentDisplayName  String?

  planCode            String       @default("FREE")
  subscriptionStatus  String       @default("ACTIVE")
  planStartedAt       DateTime?
  planExpiresAt       DateTime?

  roles             Role[]
  members           TenantUser[]
  clients           Client[]
  items             Item[]
  sequences         DocumentSequence?
  receipts          Receipt[]
  reminderLogs      ReminderLog[]
  refreshTokens     RefreshToken[]
  quotes            Quote[]
  quoteLines        QuoteLine[]
  invoiceActivities InvoiceActivity[]
  invoices          Invoice[]
  invoiceLines      InvoiceLine[]
  invoiceViews      InvoiceView[]
  recurringInvoices RecurringInvoice[]
  exchangeRates     ExchangeRate[]
  paymentAttempts   PaymentAttempt[]
  auditLogs         AuditLog[]
  notifications     Notification[]
  attachments       InvoiceAttachment[]

  subscriptionUpgradeRequests SubscriptionUpgradeRequest[]
}

model ReminderLog {
  id           String   @id @default(uuid())
  tenantId     String
  invoiceId    String
  clientId     String
  email        String?
  reminderType String
  subject      String
  sentAt       DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])
  client  Client  @relation(fields: [clientId], references: [id])

  @@index([tenantId])
  @@index([invoiceId])
  @@index([clientId])
  @@index([sentAt])
}

model User {
  id           String   @id @default(uuid())
  fullName     String
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  memberships   TenantUser[]
  refreshTokens RefreshToken[]
}

model Role {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  createdAt DateTime @default(now())

  tenant  Tenant       @relation(fields: [tenantId], references: [id])
  members TenantUser[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model TenantUser {
  tenantId  String
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@id([tenantId, userId])
  @@index([userId])
  @@index([tenantId])
}

model Client {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())

  portalToken String? @unique

  isArchived Boolean   @default(false)
  archivedAt DateTime?

  tenant            Tenant             @relation(fields: [tenantId], references: [id])
  paymentAttempts   PaymentAttempt[]
  quotes            Quote[]
  invoices          Invoice[]
  recurringInvoices RecurringInvoice[]
  reminderLogs      ReminderLog[]

  @@index([tenantId])
}

model Item {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  unitPrice   Int      @default(0)
  costPrice   Int      @default(0)
  isService   Boolean  @default(true)
  createdAt   DateTime @default(now())

  isArchived Boolean   @default(false)
  archivedAt DateTime?

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  quoteLines   QuoteLine[]
  invoiceLines InvoiceLine[]

  @@index([tenantId])
}

model InvoiceView {
  id        String   @id @default(uuid())
  tenantId  String
  invoiceId String
  publicId  String
  viewedAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([invoiceId])
  @@index([publicId])
  @@index([tenantId])
}

model RecurringInvoiceLine {
  id String @id @default(uuid())

  recurringInvoiceId String
  itemId             String?

  isArchived Boolean   @default(false)
  archivedAt DateTime?

  name        String
  description String?

  quantity  Int
  unitPrice Int
  costPrice Int
  lineTotal Int

  recurringInvoice RecurringInvoice @relation(fields: [recurringInvoiceId], references: [id])

  @@index([recurringInvoiceId])
}

model DocumentSequence {
  tenantId      String   @id
  invoicePrefix String   @default("INV-")
  quotePrefix   String   @default("Q-")
  receiptPrefix String   @default("RCT-")
  invoiceNext   Int      @default(1)
  quoteNext     Int      @default(1)
  receiptNext   Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tenantId  String
  tokenHash String
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  expiresAt DateTime

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([userId])
  @@index([tenantId])
}

model Quote {
  id       String @id @default(uuid())
  tenantId String
  number   String
  clientId String

  status    String    @default("DRAFT")
  issueDate DateTime  @default(now())
  dueDate   DateTime?
  notes     String?

  convertedToInvoiceId String?   @unique
  convertedAt          DateTime?

  subtotal Int @default(0)
  taxTotal Int @default(0)
  total    Int @default(0)

  currency     CurrencyCode @default(ZMW)
  fxRateToBase Int          @default(1000000)
  baseTotal    Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant      @relation(fields: [tenantId], references: [id])
  client  Client      @relation(fields: [clientId], references: [id])
  lines   QuoteLine[]
  invoice Invoice?

  @@unique([tenantId, number])
  @@index([tenantId, clientId])
}

model QuoteLine {
  id       String  @id @default(uuid())
  tenantId String
  quoteId  String
  itemId   String?

  name        String
  description String?
  quantity    Int     @default(1)
  unitPrice   Int     @default(0)
  costPrice   Int     @default(0)
  lineTotal   Int     @default(0)

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  quote  Quote  @relation(fields: [quoteId], references: [id])
  item   Item?  @relation(fields: [itemId], references: [id])

  @@index([tenantId, quoteId])
}

model InvoiceActivity {
  id          String   @id @default(uuid())
  tenantId    String
  invoiceId   String
  action      String
  description String?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([invoiceId])
}

model Invoice {
  id       String  @id @default(uuid())
  tenantId String
  number   String
  clientId String
  quoteId  String? @unique
  publicId String? @unique

  status    String    @default("DRAFT")
  issueDate DateTime  @default(now())
  dueDate   DateTime?
  notes     String?

  currency     CurrencyCode @default(ZMW)
  fxRateToBase Int          @default(1000000)
  baseTotal    Int          @default(0)

  subtotal   Int @default(0)
  taxTotal   Int @default(0)
  total      Int @default(0)
  amountPaid Int @default(0)

  currencyCode CurrencyCode  @default(ZMW)
  fxRate       Int?
  fxFrom       CurrencyCode?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id])
  client          Client              @relation(fields: [clientId], references: [id])
  quote           Quote?              @relation(fields: [quoteId], references: [id])
  lines           InvoiceLine[]
  receipts        Receipt[]
  reminderLogs    ReminderLog[]
  paymentAttempts PaymentAttempt[]
  attachments     InvoiceAttachment[]

  @@unique([tenantId, number])
  @@index([tenantId, clientId])
}

model InvoiceLine {
  id        String  @id @default(uuid())
  tenantId  String
  invoiceId String
  itemId    String?

  name        String
  description String?
  quantity    Int     @default(1)
  unitPrice   Int     @default(0)
  costPrice   Int     @default(0)
  lineTotal   Int     @default(0)

  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])
  item    Item?   @relation(fields: [itemId], references: [id])

  @@index([tenantId, invoiceId])
}

model Receipt {
  id        String @id @default(uuid())
  tenantId  String
  number    String
  invoiceId String

  amount    Int
  method    String?
  reference String?
  notes     String?

  createdAt DateTime @default(now())

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  invoice         Invoice          @relation(fields: [invoiceId], references: [id])
  paymentAttempts PaymentAttempt[]

  @@unique([tenantId, number])
  @@index([tenantId, invoiceId])
}

enum CurrencyCode {
  ZMW
  USD
  ZAR
  EUR
  GBP
}

enum RecurringInterval {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  SEND
  EXPORT
}

enum PaymentAttemptStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
}

enum PaymentChannel {
  MOBILE_MONEY
  BANK_TRANSFER
  CASH
  OTHER
}

model RecurringInvoice {
  id       String @id @default(uuid())
  tenantId String
  clientId String

  name         String
  currencyCode String

  interval      RecurringInterval
  intervalCount Int               @default(1)

  nextRunDate DateTime
  lastRunDate DateTime?

  issueDays Int @default(0)
  dueDays   Int @default(7)

  isArchived Boolean   @default(false)
  archivedAt DateTime?

  subtotal Int
  taxTotal Int
  total    Int

  active Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])
  client Client @relation(fields: [clientId], references: [id])

  lines RecurringInvoiceLine[]

  @@index([tenantId])
  @@index([clientId])
}

model ExchangeRate {
  id       String       @id @default(uuid())
  tenantId String
  from     CurrencyCode
  to       CurrencyCode
  rate     Int
  asOfDate DateTime     @default(now())

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
}

model PaymentAttempt {
  id        String @id @default(uuid())
  tenantId  String
  invoiceId String
  clientId  String

  channel PaymentChannel
  status  PaymentAttemptStatus @default(PENDING)

  amount     Int
  payerName  String?
  payerPhone String?
  reference  String?
  notes      String?
  proofUrl   String?

  reviewedBy       String?
  reviewedAt       DateTime?
  createdReceiptId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  receipt Receipt? @relation(fields: [createdReceiptId], references: [id])
  invoice Invoice  @relation(fields: [invoiceId], references: [id])
  client  Client   @relation(fields: [clientId], references: [id])

  @@index([tenantId])
  @@index([invoiceId])
  @@index([clientId])
}

model AuditLog {
  id          String      @id @default(uuid())
  tenantId    String
  userId      String?
  entityType  String
  entityId    String
  action      AuditAction
  description String?
  metadata    String?

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model Notification {
  id         String    @id @default(uuid())
  tenantId   String
  userId     String?
  type       String
  title      String
  message    String?
  entityType String?
  entityId   String?
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}

model InvoiceAttachment {
  id           String   @id @default(uuid())
  tenantId     String
  invoiceId    String
  filename     String
  originalName String
  mimetype     String
  size         Int
  path         String
  createdAt    DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([tenantId])
  @@index([invoiceId])
}

model SubscriptionUpgradeRequest {
  id                 String   @id @default(uuid())
  tenantId           String
  requestedPlanCode  String
  currentPlanCode    String
  status             String   @default("PENDING") // PENDING | APPROVED | REJECTED
  notes              String?
  requestedAt        DateTime @default(now())
  reviewedAt         DateTime?
  reviewedByUserId   String?

  paymentStatus      String   @default("PENDING") // PENDING | SUBMITTED | CONFIRMED | REJECTED
  paymentMethod      String?
  paymentReference   String?
  paymentProofUrl    String?
  paymentNotes       String?
  paymentSubmittedAt DateTime?
  paymentReviewedAt  DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([status])
  @@index([requestedAt])
}
